@using PeopleHub.Domain.Enums
@model IReadOnlyCollection<PeopleHub.Domain.Model.PersonInfo>

@{
    ViewBag.Title = "Люди";
    Layout = "_Layout";
}
<form id="searchForm" method="get" action="@Url.Action("Search", "Person")" class="mb-3">
    <div class="row g-2 align-items-start">
        <div class="col">
            <input type="text" name="firstName" value="@ViewBag.SearchFirstName" class="form-control" placeholder="Имя" />
        </div>
        <div class="col">
            <input type="text" name="lastName" value="@ViewBag.SearchLastName" class="form-control" placeholder="Фамилия" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </div>
</form>
@{
    var searchError = ViewBag.SearchError as string;
}
<div id="searchError" class="alert alert-warning" style="@(string.IsNullOrEmpty(searchError) ? "display:none" : "")">
    @searchError
</div>
<script>
    (function () {
        var form = document.getElementById('searchForm');
        var alertEl = document.getElementById('searchError');
        if (form && alertEl) {
            form.addEventListener('submit', function () {
                alertEl.style.display = 'none';
                alertEl.textContent = '';
            });
        }
    })();
</script>
@if (string.IsNullOrEmpty(searchError) && Model.Count > 0)
{
    <table class="table table-striped table-bordered table-hover">
        <thead class="thead-light">
        <tr>
            <th scope="col">Фамилия, имя</th>
            <th scope="col">Возраст</th>
            <th scope="col">Город</th>
            <th scope="col">#</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var person in Model)
        {
            <tr>
                <td>
                    <a href="@Url.Action("Person", "Person", new {personId = person.Person.Id})">
                        @person.Person.Name
                    </a>
                </td>
                <td>@person.Person.Age</td>
                <td>@person.Person.City</td>
                <td>
                    @switch (person.Status)
                    {
                        case FriendRequestStatus.None:
                            <a class="btn btn-success" title="Добавить в друзья" href="@Url.Action("SendFriendRequest", "Friends", new {targetPersonId = person.Person.Id, returnUrl = Url.Action("Index", "Person")})"><i class="fa fa-user-plus"></i></a>
                            break;
                        case FriendRequestStatus.Sent:
                        case FriendRequestStatus.Rejected:
                            <div class="alert alert-info"><i class="fa fa-clock"></i> Заявка отправлена</div>
                            break;
                        case FriendRequestStatus.Approved:
                            <div class="alert alert-success"><i class="fa fa-check"></i> У вас в друзьях</div>
                            <a class="btn btn-danger" title="Удалить из друзей" href="@Url.Action("CancelRequest", "Friends", new {targetPersonId = person.Person.Id, returnUrl = Url.Action("Index")})"><i class="fa fa-user-times"></i></a>
                            break;
                        default:
                            <div class="alert alert-danger"><strong>Неизвестный статус заявки: @person.Status.ToString("F")</strong></div>
                            break;
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (string.IsNullOrEmpty(searchError))
{
    <div class="alert alert-info">Нет данных по людям</div>
}
@model IReadOnlyCollection<PeopleHub.Domain.Model.PersonInfo>

@{
    ViewBag.Title = "Люди";
    Layout = "_Layout";
    var searchError = ViewBag.SearchError as string;
    var searchFirstName = ViewBag.SearchFirstName as string ?? string.Empty;
    var searchLastName = ViewBag.SearchLastName as string ?? string.Empty;
    var pageSize = (int)(ViewBag.PageSize ?? 20);
}
<form id="searchForm" method="get" action="@Url.Action("Search", "Person")" class="mb-3">
    <div class="row g-2 align-items-start">
        <div class="col">
            <input type="text" name="firstName" value="@ViewBag.SearchFirstName" class="form-control" placeholder="Имя" />
        </div>
        <div class="col">
            <input type="text" name="lastName" value="@ViewBag.SearchLastName" class="form-control" placeholder="Фамилия" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </div>
</form>
<div id="searchError" class="alert alert-warning" style="@(string.IsNullOrEmpty(searchError) ? "display:none" : "")">
    @searchError
</div>
<script>
    (function () {
        let form = document.getElementById('searchForm');
        let alertEl = document.getElementById('searchError');
        if (form && alertEl) {
            form.addEventListener('submit', function () {
                alertEl.style.display = 'none';
                alertEl.textContent = '';
            });
        }
    })();
</script>
@if (string.IsNullOrEmpty(searchError))
{
    <style>
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1050;
        }
        .loading-overlay[hidden] {
            display: none;
        }
    </style>
    <div id="loadingOverlay" class="loading-overlay" hidden>
        <div class="spinner-border text-light" role="status" style="width: 10rem; height: 10rem;">
            <span class="visually-hidden">Загрузка...</span>
        </div>
    </div>
    <div id="noData" class="alert alert-info" hidden>Нет данных по людям</div>
    <div id="personsList"
         data-page-size="@pageSize"
         data-load-url="@Url.Action("LoadMore", "Person")"
         data-search-first-name="@searchFirstName"
         data-search-last-name="@searchLastName">
        <table id="personsTable" class="table table-striped table-bordered table-hover" hidden>
            <thead class="thead-light">
            <tr>
                <th scope="col">Фамилия, имя</th>
                <th scope="col">Возраст</th>
                <th scope="col">Город</th>
                <th scope="col">#</th>
            </tr>
            </thead>
            <tbody></tbody>
        </table>
        <div id="scrollSentinel" style="height:1px;"></div>
    </div>
    <script>
        (function () {
            let list = document.getElementById('personsList');
            if (!list) return;

            let table = document.getElementById('personsTable');
            let tbody = list.querySelector('tbody');
            if (!tbody) return;

            let overlay = document.getElementById('loadingOverlay');
            let noData = document.getElementById('noData');

            let skip = 0;
            let pageSize = parseInt(list.dataset.pageSize, 10) || 20;
            let hasMore = true;
            let loadUrl = list.dataset.loadUrl;
            let firstName = list.dataset.searchFirstName || '';
            let lastName = list.dataset.searchLastName || '';
            let loading = false;

            let sentinel = document.getElementById('scrollSentinel');
            if (!sentinel) return;

            function showOverlay() {
                if (overlay) overlay.hidden = false;
            }

            function hideOverlay() {
                if (overlay) overlay.hidden = true;
            }

            function buildUrl() {
                let params = new URLSearchParams();
                params.set('skip', String(skip));
                if (firstName) params.set('firstName', firstName);
                if (lastName) params.set('lastName', lastName);
                return loadUrl + '?' + params.toString();
            }

            function isSentinelNearViewport() {
                let rect = sentinel.getBoundingClientRect();
                return rect.top < window.innerHeight + 200;
            }

            function loadMore() {
                if (loading || !hasMore) return;
                loading = true;
                showOverlay();
                fetch(buildUrl(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(function (res) {
                        if (!res.ok) throw new Error('Failed to load');
                        return res.text();
                    })
                    .then(function (html) {
                        html = html.trim();
                        let tmp = document.createElement('tbody');
                        tmp.innerHTML = html;
                        let newRows = tmp.querySelectorAll('tr');
                        if (newRows.length === 0) {
                            hasMore = false;
                            if (skip === 0 && noData) {
                                noData.hidden = false;
                            }
                            loading = false;
                            hideOverlay();
                            return;
                        }
                        for (let i = 0; i < newRows.length; i++) {
                            tbody.appendChild(newRows[i]);
                        }
                        if (skip === 0 && table) {
                            table.hidden = false;
                        }
                        skip += newRows.length;
                        if (newRows.length < pageSize) {
                            hasMore = false;
                        }
                        loading = false;
                        hideOverlay();
                        if (hasMore) {
                            requestAnimationFrame(function () {
                                if (isSentinelNearViewport()) {
                                    loadMore();
                                }
                            });
                        }
                    })
                    .catch(function () {
                        loading = false;
                        hideOverlay();
                    });
            }

            let observer = new IntersectionObserver(function (entries) {
                if (entries[0].isIntersecting) {
                    loadMore();
                }
            }, { rootMargin: '200px 0px' });
            observer.observe(sentinel);
        })();
    </script>
}

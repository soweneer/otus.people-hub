@model IReadOnlyCollection<PeopleHub.Domain.Model.PersonInfo>

@{
    ViewBag.Title = "Люди";
    Layout = "_Layout";
    var searchError = ViewBag.SearchError as string;
    var searchFirstName = ViewBag.SearchFirstName as string ?? string.Empty;
    var searchLastName = ViewBag.SearchLastName as string ?? string.Empty;
    var pageSize = (int)(ViewBag.PageSize ?? 20);
    var canLoadMore = Model.Count >= pageSize;
}
<form id="searchForm" method="get" action="@Url.Action("Search", "Person")" class="mb-3">
    <div class="row g-2 align-items-start">
        <div class="col">
            <input type="text" name="firstName" value="@ViewBag.SearchFirstName" class="form-control" placeholder="Имя" />
        </div>
        <div class="col">
            <input type="text" name="lastName" value="@ViewBag.SearchLastName" class="form-control" placeholder="Фамилия" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </div>
</form>
<div id="searchError" class="alert alert-warning" style="@(string.IsNullOrEmpty(searchError) ? "display:none" : "")">
    @searchError
</div>
<script>
    (function () {
        var form = document.getElementById('searchForm');
        var alertEl = document.getElementById('searchError');
        if (form && alertEl) {
            form.addEventListener('submit', function () {
                alertEl.style.display = 'none';
                alertEl.textContent = '';
            });
        }
    })();
</script>
@if (string.IsNullOrEmpty(searchError) && Model.Count > 0)
{
    <div id="personsList"
         data-skip="@Model.Count"
         data-page-size="@pageSize"
         data-has-more="@(canLoadMore ? "true" : "false")"
         data-load-url="@Url.Action("LoadMore", "Person")"
         data-search-first-name="@searchFirstName"
         data-search-last-name="@searchLastName">
        <table class="table table-striped table-bordered table-hover">
            <thead class="thead-light">
            <tr>
                <th scope="col">Фамилия, имя</th>
                <th scope="col">Возраст</th>
                <th scope="col">Город</th>
                <th scope="col">#</th>
            </tr>
            </thead>
            <tbody>
            @await Html.PartialAsync("_PersonRows", Model)
            </tbody>
        </table>
    </div>
    <script>
        (function () {
            var list = document.getElementById('personsList');
            if (!list) return;
            if (list.dataset.hasMore !== 'true') return;

            var tbody = list.querySelector('tbody');
            if (!tbody) return;

            var skip = parseInt(list.dataset.skip, 10) || 0;
            var pageSize = parseInt(list.dataset.pageSize, 10) || 20;
            var hasMore = true;
            var loadUrl = list.dataset.loadUrl;
            var firstName = list.dataset.searchFirstName || '';
            var lastName = list.dataset.searchLastName || '';
            var loading = false;

            function buildUrl() {
                var params = new URLSearchParams();
                params.set('skip', String(skip));
                if (firstName) params.set('firstName', firstName);
                if (lastName) params.set('lastName', lastName);
                return loadUrl + '?' + params.toString();
            }

            function isNearBottom() {
                return window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 200;
            }

            function loadMore() {
                if (loading || !hasMore) return;
                if (!isNearBottom()) return;
                loading = true;
                fetch(buildUrl(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(function (res) {
                        if (!res.ok) throw new Error('Failed to load');
                        return res.text();
                    })
                    .then(function (html) {
                        html = html.trim();
                        if (!html) {
                            hasMore = false;
                            loading = false;
                            return;
                        }
                        var tmp = document.createElement('tbody');
                        tmp.innerHTML = html;
                        var newRows = tmp.querySelectorAll('tr');
                        for (var i = 0; i < newRows.length; i++) {
                            tbody.appendChild(newRows[i]);
                        }
                        skip += newRows.length;
                        if (newRows.length < pageSize) {
                            hasMore = false;
                        }
                        loading = false;
                        loadMore();
                    })
                    .catch(function () {
                        loading = false;
                    });
            }

            window.addEventListener('scroll', loadMore, { passive: true });
            window.addEventListener('resize', loadMore, { passive: true });
            loadMore();
        })();
    </script>
}
else if (string.IsNullOrEmpty(searchError))
{
    <div class="alert alert-info">Нет данных по людям</div>
}

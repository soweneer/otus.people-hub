{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "RunMigrationsOnStartup": true,
  "Citus": {
    "Enabled": true,
    "CoordinatorHost": "citus-coordinator",
    "CoordinatorPort": 5432,
    "ShardCount": 16,
    "Workers": [
      { "Host": "citus-worker-1", "Port": 5432 },
      { "Host": "citus-worker-2", "Port": 5432 }
    ]
  }
}
